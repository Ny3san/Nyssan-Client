{
  "schemaVersion": 1,
  "id": "nyssan",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "Nyssan"
  ],
  "contact": {
    "sources": "https://github.com/nyssan/nyssan-client"
  },
  "license": "MIT",
  "icon": "assets/nyssan/icon.png",
